{
  "appId": "com.carfocx.mediaforge",
  "productName": "MediaForge",
  "directories": {
    "output": "dist"
  },
  "files": [
    "main.js",
    "preload.js",
    "setup-preload.js",
    "package.json",
    "renderer/**/*",
    "node-tools/**/*",
    "python/**/*",
    "!python/weights/**",
    "!python/**/__pycache__/**",
    "!**/*.pyc"
  ],
  "extraResources": [
    {
      "from": "build/bundle/python-env",
      "to": "python-env",
      "filter": ["**/*"]
    },
    {
      "from": "build/bundle/ffmpeg",
      "to": "ffmpeg",
      "filter": ["**/*"]
    }
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "icon": "build/icon.png"
  },
  "nsis": {
    "oneClick": true,
    "perMachine": false,
    "deleteAppDataOnUninstall": false,
    "artifactName": "MediaForge-Slim-Setup.${ext}"
  },
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": ["universal"]
      }
    ],
    "icon": "build/icon.png",
    "category": "public.app-category.utilities",
    "identity": null
  },
  "dmg": {
    "artifactName": "MediaForge-Slim-Setup.${ext}"
  },
  "linux": {
    "target": [
      {
        "target": "AppImage",
        "arch": ["x64"]
      }
    ],
    "icon": "build/icon.png",
    "category": "Utility"
  }
}
